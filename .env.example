# 应用配置
APP_PORT=8080
PROFILE=prod

# 数据库配置
DB_NAME=shanghai_learning
DB_USER=root
DB_PASSWORD=your_secure_password_here
MYSQL_PORT=3306

# Redis 配置
REDIS_PASSWORD=your_redis_password_here
